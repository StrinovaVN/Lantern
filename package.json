{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "lantern",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "NODE_ENV=development bun run  --watch src/index.ts",
    "build": "rm -rf dist && bun build ./src/index.ts --target bun --outdir dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "copyfiles": "cp src/config.toml dist/ && cp .env dist/ && cp openapi.json dist/",
    "register:commands": "NODE_ENV=development bun src/scripts/registerCommands.ts",
    "unregister:commands": "NODE_ENV=development bun src/scripts/unregisterCommands.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StrinovaVN/lantern.git"
  },
  "bugs": {
    "url": "https://github.com/StrinovaVN/lantern/issues"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^8.0.0",
    "@types/bun": "^1.3.14",
    "eslint": "^10.5.0",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@elysia/cors": "^1.4.2",
    "@elysia/cron": "^1.4.2",
    "@elysia/openapi": "^1.4.15",
    "@iarna/toml": "^2.2.5",
    "archiver": "^7.0.1",
    "chalk": "^4.1.2",
    "date-fns": "^4.4.0",
    "dedent": "^1.7.2",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "elysia": "^1.4.29",
    "mongodb": "^6.21.0",
    "mongoose": "^8.24.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
