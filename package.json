{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "lantern",
  "version": "1.4.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "bun run  --watch src/index.ts",
    "build": "rm -rf dist && mkdir dist && bun run unregister:commands && bun run register:commands && bun run copyfiles && bun build ./src/index.ts --outdir dist --target=bun --minify --packages=external",
    "start": "NODE_ENV=production bun dist/index.js",
    "copyfiles": "cp src/config.toml dist/ && cp openapi.json dist/",
    "register:commands": "bun src/scripts/registerCommands.ts",
    "unregister:commands": "bun src/scripts/unregisterCommands.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/StrinovaVN/lantern.git"
  },
  "bugs": {
    "url": "https://github.com/StrinovaVN/lantern/issues"
  },
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/async-lock": "^1.4.2",
    "@types/compression": "^1.8.1",
    "@types/eslint__js": "^8.42.3",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/he": "^1.2.3",
    "@types/morgan": "^1.9.10",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@scalar/express-api-reference": "^0.9.13",
    "archiver": "^7.0.1",
    "async-lock": "^1.4.1",
    "axios": "^1.15.2",
    "body-parser": "^1.20.5",
    "chalk": "^4.1.2",
    "chrono-node": "^2.9.0",
    "compression": "^1.8.1",
    "cron": "^3.5.0",
    "cronstrue": "^2.61.0",
    "date-fns": "^4.1.0",
    "dedent": "^1.7.2",
    "discord.js": "^14.26.3",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-file-routing": "^3.1.0",
    "express-validator": "^7.3.2",
    "express-ws": "^5.0.2",
    "he": "^1.2.0",
    "moment": "^2.30.1",
    "mongodb": "^6.21.0",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.1",
    "ms": "^2.1.3",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
