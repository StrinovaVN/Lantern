{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "dom"
    ],
    "paths": {
      "@/*": ["./*"],
      "@/utils/*": ["./src/lib/utils/*"],
      "@/scripts/*": ["./src/scripts/*"],
      "@/models/*": ["./src/lib/models/*"],
      "@/elysia/*": ["./src/lib/elysia/*"],
      "@/bot/*": ["./src/lib/bot/*"],
    },
    "rootDir": "./",
    "outDir": "./dist",
    "module": "Preserve",
    "target": "ES2023",
    "skipLibCheck": true
  }
}
